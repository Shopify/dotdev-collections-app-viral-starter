# Copy this file to `.env` before `pnpm run setup` (see README).
# Leave SHOPIFY_* empty for local CLI linking; DATABASE_URL is required for Prisma.

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=https://localhost:3000
SCOPES=write_products,read_products,read_inventory,read_publications,write_publications
DATABASE_URL="file:./dev.sqlite"
